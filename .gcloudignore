cat > .gcloudignore << 'EOF'
.git
.gitignore
.gcloudignore

# Node
node_modules/
npm-debug.log
yarn-error.log
**/node_modules/

# Java/Maven/Gradle
**/target/
**/.gradle/
**/build/
*.class
*.war

# Allow gradle wrapper jar (required for ./gradlew)
!gradle/wrapper/gradle-wrapper.jar
!**/gradle/wrapper/gradle-wrapper.jar

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/.venv/
**/venv/
**/*.egg-info/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test/coverage
**/coverage/
**/.nyc_output/
EOF