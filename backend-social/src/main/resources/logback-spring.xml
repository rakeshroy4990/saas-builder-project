<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">
  <springProperty scope="context" name="APP_LOG_LEVEL" source="APP_LOG_LEVEL" defaultValue="INFO"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level trace=%X{traceId:-na} %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="com.flexshell" level="${APP_LOG_LEVEL}"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
