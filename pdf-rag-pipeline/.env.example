# --- RAG document store (no Spring application.properties; this file + config/settings.py) ---
# mongo (default): uses MONGO_URI + MONGO_DB below.
# postgres: set APP_PERSISTENCE_PROVIDER=postgres and DATABASE_URL; MONGO_URI is not used.
APP_PERSISTENCE_PROVIDER=mongo
MONGO_URI=mongodb://localhost:27017
MONGO_DB=rag_db
# Supabase / Postgres URI for psycopg (postgresql://... or postgres://...). Required when APP_PERSISTENCE_PROVIDER=postgres.
DATABASE_URL=
# Full-text rank floor (Postgres ts_rank_cd scale differs from Mongo textScore); tune if retrieval is too strict/loose.
PG_TEXT_SEARCH_MIN_SCORE=0.02

JWT_SECRET=your-spring-boot-shared-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ISSUER=medicheck-backend
JWT_AUDIENCE=web

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GEMINI_API_KEY=

TEXT_SEARCH_MIN_SCORE=0.5
MAX_CHUNKS=5
MAX_CONTEXT_TOKENS=2000
MIN_CHUNKS_REQUIRED=1
CACHE_TTL_HOURS=12
PDF_DIR=./pdfs
RAG_LOG_FULL_PROMPT=false
RAG_LOG_PROMPT_PREVIEW_CHARS=400
APP_LOG_LEVEL=INFO
DOMAIN_POINTS_FILE=config/domain_points.json
CORS_ORIGINS=http://localhost:5173
