# Frontend environment variables
VITE_SPRING_API_BASE_URL=http://localhost:8080
VITE_DEFAULT_PACKAGE_NAME=hospital
VITE_DEFAULT_PAGE_ID=home

# Public Cloudinary delivery base URL for UI image rendering.
VITE_CLOUDINARY_IMAGE_BASE_URL=https://res.cloudinary.com/dbke33vfd/image/upload

# WebRTC: STUN + TURN. Same machine as coturn → 127.0.0.1:3478; other device on LAN → use that machine’s LAN IP (not 127.0.0.1).
# Optional: VITE_WEBRTC_ICE_TRANSPORT_POLICY=relay only when every peer can reach this TURN host.
VITE_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:127.0.0.1:3478"],"username":"webrtc","credential":"changeme"}]