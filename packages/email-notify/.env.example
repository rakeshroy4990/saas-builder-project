RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM_ADDRESS=onboarding@resend.dev
APP_BASE_URL=https://app.yourdomain.com
RESET_TOKEN_TTL_SECONDS=3600
# Optional: shared secret for POST /hospital/appointment-created (must match backend APP_EMAIL_INTERNAL_SECRET).
# Use a long random string in production (e.g. openssl rand -hex 32). Example for local dev only:
# EMAIL_INTERNAL_SECRET=local-dev-example_do_not_use_in_prod_7xK9mN2pQ4vR8sT1
# Optional: port for npm run serve:hospital-appointment-email (default 8787).
# HOSPITAL_APPOINTMENT_EMAIL_PORT=8787
