# Copy to `.env` and fill in values. `.env` is gitignored.
# `./gradlew bootRun` merges this file into the process environment (see build.gradle).
# For IDE runs without Gradle, export these or use an Env File plugin.

# --- Persistence (FlexShellApplication reads APP_PERSISTENCE_PROVIDER before Spring) ---
APP_PERSISTENCE_PROVIDER=mongo

# --- MongoDB (omit both blocks when using postgres-only) ---
# Preferred full URI:
# SPRING_DATA_MONGODB_URI=
# Or URL + password (<db_password> token) or {{OTHER_ENV}} placeholders in MONGODB_URL:
# MONGODB_URL=
# MONGODB_PASSWORD=

# --- JDBC / Flyway (when APP_PERSISTENCE_PROVIDER=postgres) ---
# Supabase direct db.*.host is IPv6-only; use Session pooler from Dashboard if local connection fails.
# Example session pooler: jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#   + SPRING_DATASOURCE_USERNAME=postgres.<project-ref> (see Supabase "Connect" / Database settings).
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_MAX_POOL_SIZE=10

# --- Server ---
PORT=8080
SERVER_FORWARD_HEADERS_STRATEGY=framework

# --- Spring JPA (fixed in application.properties; override via env if needed) ---
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_OPEN_IN_VIEW=false
SPRING_JPA_PROPERTIES_HIBERNATE_JDBC_TIME_ZONE=UTC

APP_MONGODB_DATABASE=flexshell
APP_LOG_LEVEL=INFO

APP_AUTH_JWT_SECRET=change-this-jwt-secret-min-32-bytes
APP_AUTH_JWT_ISSUER=flexshell-hospital
APP_AUTH_JWT_ACCESS_EXPIRATION_SECONDS=900
APP_AUTH_JWT_REFRESH_EXPIRATION_SECONDS=2592000
APP_AUTH_PASSWORD_MIN_LENGTH=12
APP_AUTH_PASSWORD_REQUIRE_MIXED=true
APP_AUTH_LOGIN_RATE_LIMIT_MAX=30
APP_AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_AUTH_COOKIE_DOMAIN=
APP_AUTH_COOKIE_ACCESS_TOKEN_NAME=access_token
APP_AUTH_COOKIE_CROSS_SITE_DEPLOYMENT=false
APP_AUTH_COOKIE_REFRESH_MAX_AGE_SECONDS=2592000
APP_AUTH_COOKIE_ACCESS_MAX_AGE_SECONDS=900
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,https://localhost:*
APP_SECURITY_HSTS_ENABLED=false
APP_SECURITY_HSTS_MAX_AGE_SECONDS=31536000
APP_SECURITY_CSP_POLICY=
APP_PATIENT_DATA_ENCRYPTION_KEY=
APP_BOOTSTRAP_ADMIN_ENABLED=false
APP_BOOTSTRAP_ADMIN_EMAIL=
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_FIRST_NAME=System
APP_BOOTSTRAP_ADMIN_LAST_NAME=Admin
APP_SEED_USERS_ENABLED=false
APP_SEED_USERS_DEFAULT_PASSWORD=ChangeMe123!
APP_HOSPITAL_TIME_ZONE=UTC

APP_VIDEO_PROVIDER=builtin
APP_VIDEO_AGORA_APP_ID=
APP_VIDEO_AGORA_APP_CERTIFICATE=
APP_VIDEO_AGORA_TOKEN_TTL_SECONDS=3600
APP_VIDEO_JOIN_CALL_GRACE_MINUTES=10
APP_VIDEO_JOIN_CALL_ALLOWED_STATUSES=CONFIRMED,Open
APP_VIDEO_CALL_MAX_DURATION_HOURS=4

APP_AI_PROVIDER=openai
APP_AI_SYSTEM_PROMPT=
APP_AI_TIMEOUT_MS=12000
APP_AI_MAX_TOKENS=400
APP_AI_TEMPERATURE=0.3
APP_AI_BLOG_MAX_TOKENS=1200
APP_AI_BLOG_TEMPERATURE=0.75
APP_AI_BLOG_CACHE_TTL_HOURS=12
APP_AI_OPENAI_API_KEY=
APP_AI_OPENAI_MODEL=gpt-4o-mini
APP_AI_OPENAI_BASE_URL=https://api.openai.com
APP_AI_OPENAI_CHAT_PATH=/v1/chat/completions
APP_AI_GEMINI_API_KEY=
APP_AI_GEMINI_MODEL=gemini-1.5-flash
APP_AI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
APP_AI_GEMINI_CHAT_PATH_TEMPLATE=/v1beta/models/%s:generateContent
APP_AI_CLAUDE_API_KEY=
APP_AI_CLAUDE_MODEL=claude-3-5-sonnet-latest
APP_AI_CLAUDE_BASE_URL=https://api.anthropic.com
APP_AI_CLAUDE_CHAT_PATH=/v1/messages
APP_AI_CLAUDE_VERSION=2023-06-01
APP_AI_RAG_ENABLED=true
APP_AI_RAG_BASE_URL=http://localhost:8090
APP_AI_RAG_QUERY_PATH=/api/v1/query
APP_AI_RAG_RETRY_ATTEMPTS=2
APP_AI_RAG_RETRY_BACKOFF_MS=600
APP_AI_SMART_MAX_REQUESTS_PER_DAY=15
APP_AI_SMART_MAX_INPUT_TOKENS_PER_REQUEST=1200

APP_EMAIL_ENABLED=true
APP_EMAIL_INTERNAL_BASE_URL=http://localhost:8787
APP_EMAIL_PORTAL_BASE_URL=http://localhost:5174
APP_EMAIL_INTERNAL_SECRET=

SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

YOUTUBE_API_KEY=
APP_YOUTUBE_CHANNEL_HANDLE=LittleSproutsCare_DrSwati
APP_YOUTUBE_SEARCH_CACHE_TTL_MS=300000
APP_YOUTUBE_HERO_RECENT_POOL_SIZE=30
APP_YOUTUBE_HERO_RANK_BY=RANDOM
APP_YOUTUBE_QUERY_CACHE_DATABASE=rag_db
